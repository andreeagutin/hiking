{
  "name": "hiking",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/index.js",
    "client": "vite",
    "server": "nodemon --watch server server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node data/seed.js",
    "migrate:poi": "node data/migrate-caves-to-poi.js",
    "migrate:restaurants": "node data/migrate-restaurants-to-poi.js",
    "migrate:slugs": "node data/migrate-slugs.js",
    "migrate:poi-slugs": "node data/migrate-poi-slugs.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "marked": "^17.0.5",
    "mongoose": "^8.4.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "vite": "^5.3.1"
  }
}
